---
import clsx from "clsx";
const { pathname } = Astro.url;
---

<nav class="flex font-bold text-xl gap-8 md:gap-16 py-8 p-4 md:px-24">
  <a aria-label="Home page" class="text-mauve" href="/">
    <svg
      xmlns="http://www.w3.org/2000/svg"
      class="h-8 w-8"
      viewBox="0 0 576 512"
      fill="currentColor"
    >
      <path
        d="M9.4 86.6C-3.1 74.1-3.1 53.9 9.4 41.4s32.8-12.5 45.3 0l192 192c12.5 12.5 12.5 32.8 0 45.3l-192 192c-12.5 12.5-32.8 12.5-45.3 0s-12.5-32.8 0-45.3L178.7 256 9.4 86.6zM256 416H544c17.7 0 32 14.3 32 32s-14.3 32-32 32H256c-17.7 0-32-14.3-32-32s14.3-32 32-32z"
      ></path>
    </svg>
  </a>
  <a
    aria-label="Home page"
    class={clsx("hover:text-mauve", { "text-mauve": pathname === "/" })}
    href="/">Home</a
  >
  <a
    aria-label="Resume page"
    class={clsx("hover:text-mauve", { "text-mauve": pathname === "/resume" })}
    href="/resume">Resume</a
  >
  <a
    aria-label="Blog page"
    class={clsx("hover:text-mauve", {
      "text-mauve": pathname.startsWith("/blog"),
    })}
    href="/blog">Blog</a
  >
</nav>
