---
import Shell from "@layouts/shell.astro";

let experiences = [
  {
    title: "Director, Software Engineering",
    company: "LeaseAccelerator",
    duration: "May 2023 - Present",
    description: "Developed XYZ features using ABC technology.",
  },
  {
    title: "Software Engineering Manager",
    company: "Deloitte",
    duration: "Apr 2017 - May 2023",
    description: "Worked on XYZ project and learned ABC skills.",
  },
  {
    title: "Junior Developer",
    company: "Company B",
    duration: "Jan 2018 - Dec 2019",
    description: "Worked on XYZ project and learned ABC skills.",
  },
];

let skills = [
  {
    category: "Frontend",
    items: "HTML, CSS, JavaScript, React, Vue, etc.",
  },
  {
    category: "Backend",
    items: "Node.js, Express, Django, etc.",
  },
  {
    category: "Database",
    items: "MySQL, PostgreSQL, MongoDB, etc.",
  },
  {
    category: "Cloud",
    items: "MySQL, PostgreSQL, MongoDB, etc.",
  },
];
---

<Shell title="Home">
  <!-- Hero Section -->
  <section class="bg-banner bg-360 animate-banner text-base text-center py-20">
    <h1 class="text-5xl font-bold">Soham Dasgupta</h1>
    <p class="text-xl mt-4">
      Technology Leader | Enterprise Architect | Full-Stack Developer |
      Open-Source Enthusiast
    </p>
    <img
      class="mx-auto rounded-full h-48 w-48 mt-8 border-4 border-surface0"
      src="/profile.webp"
      alt="Soham Dasgupta"
    />
  </section>

  <!-- Skills Section -->
  <section class="py-20">
    <h2 class="text-4xl font-bold text-center">My Skills</h2>
    <div class="flex flex-wrap justify-center mt-8 space-y-0 gap-4">
      {
        skills.map((skill) => (
          <div class="mx-2 p-8 bg-surface0 text-text rounded-lg">
            <h3 class="text-2xl font-bold">{skill.category}</h3>
            <p>{skill.items}</p>
          </div>
        ))
      }
    </div>
  </section>

  <!-- Experience Section -->
  <section class="py-20 bg-surface0">
    <h2 class="text-4xl font-bold text-center">My Experience</h2>
    <div class="w-full mt-8 flex items-center">
      <div class="flex flex-col grid grid-cols-9 mx-auto p-2">
        {
          experiences.map((experience, index) => (
            <>
              {index % 2 === 1 && (
                <div class="col-start-5 col-end-6 mr-10 mx-auto relative">
                  <div class="h-full w-6 flex items-center justify-center">
                    <div class="h-full w-1 bg-overlay2 pointer-events-none" />
                  </div>
                  <div class="w-6 h-6 absolute top-1/2 -mt-3 rounded-full bg-mauve" />
                </div>
              )}
              <div
                class={`${
                  index % 2 === 0
                    ? "col-start-1 col-end-5 mr-auto"
                    : "col-start-6 col-end-10 ml-auto"
                }  bg-base p-4 rounded-xl my-4`}
              >
                <h3 class="font-semibold text-lg mb-1">{experience.title}</h3>
                <h4 class="text-subtext0 mb-1">{experience.company}</h4>
                <h5 class="text-subtext0 mb-1">{experience.duration}</h5>
                <p class="leading-tight text-justify text-subtext0">
                  {experience.description}
                </p>
              </div>
              {index % 2 === 0 && (
                <div class="col-start-5 col-end-6 mr-10 mx-auto relative">
                  <div class="h-full w-6 flex items-center justify-center">
                    <div class="h-full w-1 bg-overlay2 pointer-events-none" />
                  </div>
                  <div class="w-6 h-6 absolute top-1/2 -mt-3 rounded-full bg-mauve" />
                </div>
              )}
            </>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Social -->
  <section class="py-20 bg-mantle">
    <h2 class="text-4xl font-bold text-center">Social</h2>
    <p class="text-xl mt-8 text-center mt-4">
      You can reach me at your-email@example.com
    </p>
  </section>
</Shell>
